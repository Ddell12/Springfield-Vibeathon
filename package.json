{
  "name": "bridges",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently --names \"next,livekit\" --prefix-colors \"cyan,magenta\" \"NODE_OPTIONS='--max-old-space-size=8192' next dev\" \"npm run speech-coach:agent\"",
    "build": "NODE_OPTIONS='--max-old-space-size=8192' next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "snapshot": "npx tsx scripts/generate-wc-snapshot.ts",
    "postinstall": "cd artifacts/wab-scaffold && npm install --omit=dev --legacy-peer-deps --no-audit --no-fund 2>/dev/null || true",
    "seed:demo": "npx tsx scripts/seed-demo.ts",
    "seed:demo:reset": "npx tsx scripts/seed-demo.ts --reset",
    "seed:e2e": "npx tsx scripts/seed-e2e.ts",
    "speech-coach:agent": "tsx --env-file=.env.local src/features/speech-coach/livekit/entrypoint.ts dev",
    "speech-coach:agent:start": "tsx --env-file=.env.local src/features/speech-coach/livekit/entrypoint.ts start"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.0",
    "@ai-sdk/google": "^3.0.53",
    "@anthropic-ai/sdk": "^0.80.0",
    "@auth/core": "^0.37.0",
    "@convex-dev/auth": "^0.0.91",
    "@convex-dev/rag": "^0.7.2",
    "@convex-dev/rate-limiter": "^0.3.2",
    "@convex-dev/resend": "^0.2.3",
    "@convex-dev/stripe": "^0.1.4",
    "@dnd-kit/react": "^0.3.2",
    "@elevenlabs/react": "^1.0.0",
    "@google/genai": "^1.46.0",
    "@hookform/resolvers": "^5.2.2",
    "@livekit/agents": "^1.2.2",
    "@livekit/agents-plugin-google": "^1.2.2",
    "@livekit/components-core": "^0.12.13",
    "@livekit/components-react": "^2.9.20",
    "@livekit/components-styles": "^1.2.0",
    "@react-email/components": "^1.0.10",
    "@react-email/render": "^2.0.4",
    "@t3-oss/env-nextjs": "^0.13.11",
    "ai": "^6.0.137",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.34.0",
    "convex-helpers": "^0.1.114",
    "elevenlabs": "^1.59.0",
    "esbuild": "^0.27.4",
    "livekit-client": "^2.18.0",
    "livekit-server-sdk": "^2.15.0",
    "lucide-react": "^1.0.1",
    "motion": "^12.38.0",
    "nanoid": "^5.1.7",
    "next": "16.2.1",
    "next-themes": "^0.4.6",
    "prism-react-renderer": "^2.4.1",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-error-boundary": "^6.1.1",
    "react-hook-form": "^7.72.0",
    "react-markdown": "^10.1.0",
    "react-qr-code": "^2.0.18",
    "react-resizable-panels": "^4.7.5",
    "recharts": "^3.8.1",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "resend": "^6.10.0",
    "sonner": "^2.0.7",
    "stripe": "^21.0.1",
    "tailwind-merge": "^3.5.0",
    "usehooks-ts": "^3.1.1",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@edge-runtime/vm": "^5.0.0",
    "@faker-js/faker": "^10.3.0",
    "@mswjs/interceptors": "^0.41.3",
    "@next/bundle-analyzer": "^16.2.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.19.37",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.1",
    "concurrently": "^9.2.1",
    "convex-test": "^0.0.43",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "jsdom": "^29.0.1",
    "msw": "^2.12.14",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "@esbuild/darwin-arm64",
      "@esbuild/linux-x64"
    ]
  }
}
